---
const { title = '' } = Astro.props;
---

<header class="top-bar" id="top-bar">
  <div class="top-bar-inner">
  <button class="nav-toggle" id="nav-toggle" aria-label="Toggle navigation" aria-expanded="false" aria-controls="side-nav">
    <span class="hamburger"></span>
  </button>

  <div class="search-area" id="search-area"></div>

  <div class="top-bar-right">
    <a href="/versions" class="download-btn" id="download-btn" data-pagefind-ignore>
      Download Rules
    </a>

    <button class="subscribe-btn" id="subscribe-btn" aria-label="Get updates" data-pagefind-ignore>
      Get Updates
    </button>

    <button class="theme-toggle" id="theme-toggle" aria-label="Toggle dark mode">
      <span class="theme-icon" aria-hidden="true">◐</span>
      <span class="theme-label">Theme</span>
    </button>
  </div>
  </div>
</header>

<!-- Subscribe Modal -->
<div class="modal-overlay" id="subscribe-modal" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Subscribe for updates">
  <div class="modal-content">
    <button class="modal-close" id="modal-close" aria-label="Close">✕</button>
    <div class="modal-body">
      <h2 class="modal-heading">Get Updates</h2>
      <p class="modal-desc">I post updates on my blog — get all the latest news as it&rsquo;s released.</p>
      <div class="iframe-wrapper">
        <iframe src="https://sakiroku.com/embed" width="480" height="320" style="border: none; background: var(--bg-surface); width: 100%;" frameborder="0" scrolling="no" allowtransparency="true"></iframe>
      </div>
    </div>
  </div>
</div>

<script src="/pagefind/pagefind-ui.js" is:inline></script>
<script is:inline>
  (function initSearch() {
    function mount() {
      if (typeof PagefindUI !== 'undefined') {
        new PagefindUI({
          element: '#search-area',
          showSubResults: false,
          resetStyles: true,
          pageSize: 6,
        });
      } else {
        setTimeout(mount, 50);
      }
    }
    mount();
  })();
</script>

<style>
  /* ── Top Bar ────────────────────────────────────────────────────────── */
  .top-bar {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--bg-elevated);
    border-bottom: 1px solid var(--border);
  }
  .top-bar-inner {
    display: flex;
    align-items: center;
    gap: 0.75em;
    padding: 0.6em 3em;
    max-width: 80em;
    margin: 0 auto;
    min-height: 3.2rem;
  }
  body.theme-fade .top-bar {
    transition: background 0.25s;
  }

  .nav-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.4em;
    color: var(--text-soft);
    flex-shrink: 0;
  }
  .hamburger,
  .hamburger::before,
  .hamburger::after {
    display: block;
    width: 1.25em;
    height: 2px;
    background: currentColor;
    border-radius: 1px;
    transition: transform 0.2s;
  }
  .hamburger { position: relative; }
  .hamburger::before {
    content: '';
    position: absolute;
    top: -0.45em;
  }
  .hamburger::after {
    content: '';
    position: absolute;
    top: 0.45em;
  }

  /* ── Inline search area ────────────────────────────────────────────── */
  .search-area {
    flex: 1 1 auto;
    max-width: 38em;
    min-width: 8em;
    position: relative;
  }
  .search-area :global(.pagefind-ui) {
    font-family: 'Literata Variable', Georgia, serif;
  }
  .search-area :global(.pagefind-ui__form) {
    display: flex;
    align-items: center;
    height: 2em;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 0.25em;
    transition: border-color 0.15s;
  }
  .search-area :global(.pagefind-ui__form:focus-within) {
    border-color: var(--link-col);
  }
  .search-area :global(.pagefind-ui__search-input) {
    flex: 1;
    height: 100%;
    border: none !important;
    outline: none !important;
    background: transparent !important;
    padding: 0 0.4em !important;
    font-family: 'Literata Variable', Georgia, serif !important;
    font-size: 0.8em !important;
    color: var(--text);
    line-height: 1;
    min-width: 0;
    box-shadow: none !important;
  }
  .search-area :global(.pagefind-ui__search-input::placeholder) {
    color: var(--text-muted);
    opacity: 1;
  }
  .search-area :global(.pagefind-ui__search-clear) {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    border: none;
    background: none;
    color: var(--text-muted);
    font-family: 'Literata Variable', Georgia, serif;
    font-size: 0.75em;
    cursor: pointer;
    padding: 0 0.3em;
    flex-shrink: 0;
    opacity: 0.6;
  }
  .search-area :global(.pagefind-ui__search-clear:hover) {
    opacity: 1;
    color: var(--text);
  }
  .search-area :global(.pagefind-ui__search-input::-webkit-search-decoration),
  .search-area :global(.pagefind-ui__search-input::-webkit-search-cancel-button),
  .search-area :global(.pagefind-ui__search-input::-webkit-search-results-button),
  .search-area :global(.pagefind-ui__search-input::-webkit-search-results-decoration) {
    display: none;
  }
  .search-area :global(.pagefind-ui__drawer) {
    position: absolute;
    top: calc(100% + 0.4em);
    left: 0;
    right: 0;
    z-index: 200;
    background: var(--bg-surface);
    border: none;
    border-radius: 0.25em;
    box-shadow: 0 4px 20px rgba(0,0,0,0.25);
    max-height: 70vh;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: rgba(196,146,52,0.2) transparent;
  }
  .search-area :global(.pagefind-ui__drawer:not(.pagefind-ui__hidden)) {
    border: 1px solid var(--border-strong);
  }
  .search-area :global(.pagefind-ui__drawer::-webkit-scrollbar) {
    width: 6px;
  }
  .search-area :global(.pagefind-ui__drawer::-webkit-scrollbar-track) {
    background: transparent;
  }
  .search-area :global(.pagefind-ui__drawer::-webkit-scrollbar-thumb) {
    background: rgba(196,146,52,0.25);
    border-radius: 3px;
  }
  .search-area :global(.pagefind-ui__drawer::-webkit-scrollbar-thumb:hover) {
    background: rgba(196,146,52,0.4);
  }
  .search-area :global(.pagefind-ui__message) {
    margin: 0;
    padding: 0.5em 0.75em;
    font-family: 'Literata Variable', Georgia, serif;
    font-size: 0.72em;
    color: var(--text-muted);
    border-bottom: 1px solid var(--border);
  }
  .search-area :global(.pagefind-ui__results) {
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .search-area :global(.pagefind-ui__result) {
    padding: 0;
    margin: 0;
    border-bottom: 1px solid var(--border);
    position: relative;
  }
  .search-area :global(.pagefind-ui__result:last-child) {
    border-bottom: none;
  }
  .search-area :global(.pagefind-ui__result-inner) {
    padding: 0.5em 0.75em;
    transition: background 0.1s;
    cursor: pointer;
  }
  .search-area :global(.pagefind-ui__result:hover .pagefind-ui__result-inner) {
    background: var(--nav-hover);
  }
  .search-area :global(.pagefind-ui__result-thumb) {
    display: none;
  }
  .search-area :global(.pagefind-ui__result-title) {
    margin: 0;
    padding: 0;
  }
  .search-area :global(.pagefind-ui__result-title a) {
    font-family: 'Literata Variable', Georgia, serif;
    font-variant-caps: small-caps;
    font-weight: 700;
    font-size: 0.85em;
    color: var(--heading-col);
    text-decoration: none;
    display: block;
  }
  .search-area :global(.pagefind-ui__result-title a:hover) {
    color: var(--link-col);
  }
  .search-area :global(.pagefind-ui__result-title a)::after {
    content: '';
    position: absolute;
    inset: 0;
  }
  .search-area :global(.pagefind-ui__result-excerpt) {
    margin: 0.15em 0 0;
    padding: 0;
    font-family: 'Literata Variable', Georgia, serif;
    font-size: 0.72em;
    color: var(--text-soft);
    line-height: 1.4;
  }
  .search-area :global(.pagefind-ui__result-tags) {
    margin: 0.25em 0 0;
    padding: 0;
    list-style: none;
    display: flex;
    gap: 0.3em;
    flex-wrap: wrap;
  }
  .search-area :global(.pagefind-ui__result-tag) {
    font-family: 'Literata Variable', Georgia, serif;
    font-variant-caps: small-caps;
    font-weight: 700;
    font-size: 0.6em;
    padding: 0.1em 0.45em;
    background: var(--bg-elevated);
    color: var(--text-muted);
    border-radius: 0.2em;
    display: inline-flex;
    align-items: center;
    line-height: 1.2;
  }
  .search-area :global(.pagefind-ui__button) {
    display: block;
    width: 100%;
    padding: 0.5em 0.75em;
    border: none;
    border-top: 1px solid var(--border);
    background: none;
    font-family: 'Literata Variable', Georgia, serif;
    font-variant-caps: small-caps;
    font-weight: 700;
    font-size: 0.72em;
    color: var(--link-col);
    cursor: pointer;
    text-align: center;
    transition: background 0.1s;
  }
  .search-area :global(.pagefind-ui__button:hover) {
    background: var(--nav-hover);
  }

  .top-bar-right {
    display: flex;
    align-items: center;
    gap: 0.6em;
    flex-shrink: 0;
    margin-left: auto;
  }

  /* ── Download button ─────────────────────────────────────────────── */
  .download-btn {
    display: inline-flex;
    align-items: center;
    background: transparent;
    color: var(--link);
    border: 1px solid var(--border-strong);
    border-radius: 0.25em;
    padding: 0.35em 0.75em;
    font-family: 'Literata Variable', serif;
    font-size: 0.75em;
    font-weight: 700;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.15s, border-color 0.15s;
  }
  .download-btn:hover {
    background: rgba(98,237,216,0.08);
    border-color: var(--link);
    text-decoration: none;
  }

  /* ── Subscribe button ─────────────────────────────────────────────── */
  .subscribe-btn {
    background: var(--link-col);
    color: #fff;
    border: none;
    border-radius: 0.25em;
    padding: 0.35em 0.75em;
    font-family: 'Literata Variable', serif;
    font-size: 0.75em;
    font-weight: 700;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.15s;
  }
  .subscribe-btn:hover {
    background: var(--teal-400);
  }

  /* ── Theme toggle ─────────────────────────────────────────────────── */
  .theme-toggle {
    display: flex;
    align-items: center;
    gap: 0.3em;
    background: none;
    border: 1px solid var(--border);
    border-radius: 0.25em;
    cursor: pointer;
    padding: 0.3em 0.55em;
    color: var(--text-muted);
    font-size: 0.75em;
  }
  .theme-toggle:hover {
    border-color: var(--link-col);
    color: var(--text);
  }
  body.theme-fade .theme-toggle {
    transition: border-color 0.15s, color 0.15s;
  }
  .theme-icon {
    font-size: 1.15em;
    line-height: 1;
  }
  .theme-label {
    font-family: 'Literata Variable', serif;
    font-weight: 600;
  }

  /* ── Subscribe Modal ──────────────────────────────────────────────── */
  .modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 999;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,0,0,0.55);
    backdrop-filter: blur(4px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
  }
  .modal-overlay[aria-hidden="false"] {
    opacity: 1;
    pointer-events: auto;
  }
  .modal-content {
    position: relative;
    background: var(--bg-surface);
    border-top: 2px solid var(--border-strong);
    border-bottom: 2px solid var(--border-strong);
    border-left: none;
    border-right: none;
    border-radius: 1em;
    box-shadow: 0 8px 32px rgba(0,0,0,0.3);
    max-width: 90vw;
    padding: 2em 2em 1.5em;
  }
  .modal-close {
    position: absolute;
    top: 0.6em;
    right: 0.6em;
    background: none;
    border: none;
    font-size: 1.1em;
    cursor: pointer;
    color: var(--text-muted);
    width: 1.8em;
    height: 1.8em;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.2em;
    z-index: 1;
  }
  .modal-close:hover {
    color: var(--text);
    background: var(--nav-hover);
  }
  .modal-body {
    display: flex;
    flex-direction: column;
    gap: 1.1em;
  }
  .modal-heading {
    font-family: 'Inknut Antiqua', Georgia, serif;
    font-variant-caps: small-caps;
    font-size: 1.1em;
    font-weight: 700;
    color: var(--heading-col);
    margin: 0;
    padding-right: 1.5em;
  }
  .modal-desc {
    font-size: 0.85em;
    color: var(--text-soft);
    margin: 0;
    line-height: 1.5;
  }
  .iframe-wrapper {
    border-top: 2px solid var(--gold-ui);
    border-bottom: 2px solid var(--gold-ui);
    padding: 10px 0;
    line-height: 0;
  }

  @media (max-width: 48em) {
    .nav-toggle { display: flex; }
    .theme-label { display: none; }
  }
</style>
