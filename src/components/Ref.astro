---
/**
 * <Ref slug="action-hunting" />
 *
 * Cross-references a content entry by slug. Looks up the collection
 * from slug-resolver. Renders a paper-clipping card with name, tags,
 * and available fields (duration, cost, trigger, save, rules).
 *
 * Props:
 *   slug     - the file slug (e.g. "action-hunting", "bear")
 *   label    - optional override for the display name
 *   linkSlug - optional override for the href slug
 *
 * If the entry isn't found, renders plain text with an HTML comment.
 */
import { getEntry } from "astro:content";
import { getSlugMap } from "../config/slug-resolver.js";
import { renderFullMarkdown } from "../utils/markdown.js";

const { slug, label, linkSlug } = Astro.props;
const hrefSlug = linkSlug ?? slug;

const _slugMap = getSlugMap();
const slugInfo = _slugMap[slug];
const collection = slugInfo ? slugInfo.path.split("/")[1] : null;

const collectionLabel =
  collection === "actions"    ? "Action"
  : collection === "conditions" ? "Condition"
  : collection === "spirits"    ? "Spirit"
  : collection === "bestiary"   ? "Creature"
  : collection === "tables"     ? "Table"
  : collection
    ? collection.charAt(0).toUpperCase() + collection.slice(1).replace(/^\w/, c => c.toLowerCase())
    : "";

let entry = null;
if (collection) {
  try {
    entry = await getEntry(collection, slug);
  } catch {}
}

const d = entry?.data ?? null;
const displayName = d?.name ?? label ?? slug;

function formatSave(d) {
  if (!d?.save) return "";
  if (typeof d.save === "string") return d.save;
  return d.save.type || "";
}
---

{!d && (
  <>
    <!-- TODO: missing Ref -- slug="{slug}" -->
    <span class="ref-missing">{displayName}</span>
  </>
)}

{d && (
  <div class="ref-clipping">
    <div class="ref-clipping-scrollbar"></div>
    <div class="ref-clipping-body">
      <div class="ref-clipping-header-row">
        <div class="ref-clipping-name">{displayName}</div>
        <a href={"/" + collection + "/" + hrefSlug} class="ref-clipping-link">View full {collectionLabel}</a>
      </div>
      {d.tags?.length > 0 && (
        <div class="ref-clipping-tags">
          {d.tags.map((t) => <span class="ref-tag">{t}</span>)}
        </div>
      )}
      {d.duration && <p class="ref-clipping-field"><strong>Duration:</strong> {d.duration}</p>}
      {d.cost && <p class="ref-clipping-field"><strong>Cost:</strong> {d.cost}</p>}
      {d.trigger && <p class="ref-clipping-field"><strong>Trigger:</strong> {d.trigger}</p>}
      {formatSave(d) && <p class="ref-clipping-field"><strong>Save:</strong> {formatSave(d)}</p>}
      {d.rules && <div class="ref-clipping-rules" set:html={renderFullMarkdown(d.rules, _slugMap)} />}
      {d.definition && <div class="ref-clipping-rules" set:html={renderFullMarkdown(d.definition, _slugMap)} />}
    </div>
    <div class="ref-clipping-scrollbar"></div>
  </div>
)}

<style>
  .ref-missing { color: var(--crimson-600); text-decoration: underline dotted; cursor: help; }
  .ref-missing::after { content: " [?]"; font-size: 0.8em; opacity: 0.6; }
  .ref-tag { font-size: 0.68em; font-family: "Literata Variable", serif; text-transform: capitalize; font-variant-caps: small-caps; font-weight: 700; padding: 0.15em 0.6em; background: var(--bg-elevated); color: var(--text-muted); border-radius: 0.2em; display: inline-flex; align-items: center; justify-content: center; line-height: 1.2; }
  .ref-clipping { margin: 1.5em 0; position: relative; background-color: var(--bg-surface); border: 1px solid var(--border); overflow: visible; font-family: "Literata Variable", serif; font-size: 0.9em; }
  .ref-clipping-scrollbar:first-child { position: absolute; top: -1px; left: -0.2em; width: calc(100% + 0.4em); height: 0.3em; background: var(--border-strong); box-shadow: 3px 3px 6px rgba(0,0,0,0.5); z-index: 2; }
  .ref-clipping-scrollbar:last-child { position: absolute; bottom: -1px; left: -0.2em; width: calc(100% + 0.4em); height: 0.3em; background: var(--border-strong); box-shadow: 3px 3px 6px rgba(0,0,0,0.5); z-index: 2; }
  [data-theme="dark"] .ref-clipping-scrollbar:first-child, [data-theme="dark"] .ref-clipping-scrollbar:last-child { background: var(--gold-600); }
  .ref-clipping-body { position: relative; z-index: 1; padding: 0.85em 1.1em 0.5em; box-shadow: 3px 3px 10px rgba(0,0,0,0.5); }
  .ref-clipping-header-row { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 0.2em; }
  .ref-clipping-name { font-family: "Literata Variable", serif; font-variant-caps: small-caps; font-weight: 700; font-size: 1.3em; color: var(--heading-col); }
  .ref-clipping-link { font-size: 0.75em; color: var(--link-col); text-decoration: none; font-weight: 500; white-space: nowrap; flex-shrink: 0; margin-left: 0.5em; }
  .ref-clipping-link:hover { text-decoration: underline; }
  .ref-clipping-tags { display: flex; gap: 0.4em; flex-wrap: wrap; margin-bottom: 0.5em; }
  .ref-clipping-field { font-size: 0.92em; color: var(--text-soft); margin: 0.15em 0; line-height: 1.5; }
  .ref-clipping-field strong { color: var(--text); font-weight: 600; margin-right: 0.25em; }
  .ref-clipping-rules { font-size: 0.92em; color: var(--text); margin-top: 0.6em; line-height: 1.65; clear: both; }
  .ref-clipping-rules p { margin: 0.5em 0; }
  .ref-clipping-rules ul, .ref-clipping-rules ol { margin: 0.4em 0; padding-left: 1.4em; }
  .ref-clipping-rules :global(li) { margin: 0.15em 0; }
</style>