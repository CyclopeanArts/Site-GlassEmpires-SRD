---
/**
 * <Ref collection="conditions" slug="panicked" />
 * <Ref collection="bestiary" slug="jiangshi" variant="card" />
 * <Ref collection="glossary" slug="battle-rating" variant="tooltip" />
 *
 * Renders whatever fields are present in the entry — nothing is assumed.
 * variant:
 *   "inline"  — a callout block embedded in prose (default)
 *   "card"    — compact card for index pages
 *   "tooltip" — anchor with hover summary (for <Term> usage)
 *   "stat"    — bestiary stat block format
 *
 * If the entry isn't found, renders plain text with an HTML comment.
 * Build does not fail on missing entries.
 */

import { getEntry } from 'astro:content';
import { getSlugMap } from '../config/slug-resolver.js';
import RollableTable from './RollableTable.astro';

const { collection, slug, variant = 'inline', label, linkSlug } = Astro.props;
const hrefSlug = linkSlug ?? slug;

const _slugMap = getSlugMap();

function renderFeatureText(text: string): { intro: string; bullets: string[] } {
  const lines = text.split('\n');
  const introParts: string[] = [];
  const bulletParts: string[] = [];
  let inBullets = false;
  for (const line of lines) {
    const t = line.trim();
    if (!t) continue;
    if (t.startsWith('- ')) {
      inBullets = true;
      bulletParts.push(t.slice(2));
    } else if (!inBullets) {
      introParts.push(t);
    }
  }
  return {
    intro: mdToHtml(introParts.join(' ')),
    bullets: bulletParts.map(b => mdToHtml(b))
  };
}

function wikilinksToHtml(text: string): string {
  return text
    .replace(/\[\[([^\]|]+)\|([^\]]+)\]\]/g, (_, s, lbl) => {
      const found = _slugMap[s];
      return `<a href="${found ? found.path : '/rules/' + s}">${lbl}</a>`;
    })
    .replace(/\[\[([^\]]+)\]\]/g, (_, s) => {
      const found = _slugMap[s];
      return `<a href="${found ? found.path : '/rules/' + s}">${found ? found.title : s}</a>`;
    });
}

function mdToHtml(md: string): string {
  return wikilinksToHtml(md)
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.+?)\*/g, '<em>$1</em>');
}

function renderLore(text: string): string {
  const blocks = text.split(/\n\n+/);
  const parts: string[] = [];
  for (const block of blocks) {
    const lines = block.split('\n');
    const hasBullets = lines.some(l => l.trimStart().startsWith('- '));
    if (hasBullets) {
      const items = lines
        .filter(l => l.trimStart().startsWith('- '))
        .map(l => `<li>${mdToHtml(l.trimStart().slice(2).trim())}</li>`);
      parts.push(`<ul>${items.join('\n')}</ul>`);
    } else {
      parts.push(`<p>${mdToHtml(block.replace(/\n/g, '<br>'))}</p>`);
    }
  }
  return parts.join('\n');
}

function buildSpeeds(speeds: any): { label: string; value: string }[] {
  const parts: { label: string; value: string }[] = [];
  if (speeds?.run)  parts.push({ label: 'Run', value: `${speeds.run}'` });
  if (speeds?.fly)  parts.push({ label: 'Fly', value: `${speeds.fly}'` });
  if (speeds?.swim) parts.push({ label: 'Swim', value: `${speeds.swim}'` });
  if (speeds?.dig)  parts.push({ label: 'Dig', value: `${speeds.dig}'` });
  return parts;
}

function computeBR(d: any): number | string {
  // Explicit override via frontmatter
  if (d.br !== undefined) return d.br;

  const power = (d.level || 0) + d.hd;
  const armorMult = 1 + ((d.armor || 0) / 4);
  const dmgMult = d.damagemultiplier ?? 1;
  const features = d.features || [];
  const posSum = features.reduce((s: number, f: any) => s + (f.combat > 0 ? f.combat : 0), 0);
  const negSum = features.reduce((s: number, f: any) => s + (f.combat < 0 ? Math.abs(f.combat) : 0), 0);
  const featMult = (posSum + 1) / (negSum + 1);
  return Math.round(power * armorMult * dmgMult * featMult);
}

let entry: any = null;
try {
  entry = await getEntry(collection, slug);
} catch {
  // entry not found — handled below
}

const d = entry?.data ?? null;
const displayName = d?.name ?? label ?? slug;

const hasStatFields = d && d.hd !== undefined;
const effectiveVariant = variant === 'inline' && hasStatFields ? 'stat' : variant;

// Derived stats
const power = d ? (d.level || 0) + d.hd : 0;
const hp = power * 4;
const ap = d ? (d.armor || 0) * d.hd : 0;
const br = d ? computeBR(d) : 0;
const speeds = d ? buildSpeeds(d.speeds) : '';
const weight = d?.weight !== undefined ? `${d.weight}#` : '';
const maxload = d?.maxload !== undefined ? `${d.maxload}#` : '';
---

{!d && (
  <>
    <!-- TODO: missing Ref — collection="{collection}" slug="{slug}" -->
    <span class="ref-missing">{displayName}</span>
  </>
)}

{d && effectiveVariant === 'tooltip' && (
  <a
    href={`/${collection}/${hrefSlug}`}
    class="ref-term"
    data-tooltip={d.summary ?? ''}
    aria-description={d.summary}
  >
    {displayName}
  </a>
)}

{d && effectiveVariant === 'card' && (
  <a href={`/${collection}/${hrefSlug}`} class="ref-card">
    <span class="ref-card-name">{displayName}</span>
    {d.summary && <span class="ref-card-summary">{d.summary}</span>}
    {d.tags?.length > 0 && (
      <span class="ref-card-tags">
        {d.tags.map((t: string) => <span class="ref-tag">{t}</span>)}
      </span>
    )}
  </a>
)}

{d && effectiveVariant === 'inline' && (
  <div class="ref-inline">
    <div class="ref-inline-name">{displayName}</div>
    {d.summary && <p class="ref-inline-summary">{d.summary}</p>}
    {d.duration && <p class="ref-inline-field"><strong>Duration:</strong> {d.duration}</p>}
    {d.save    && <p class="ref-inline-field"><strong>Save:</strong> {d.save}</p>}
    {d.cost    && <p class="ref-inline-field"><strong>Cost:</strong> {d.cost}</p>}
    {d.rules   && <div class="ref-inline-rules" set:html={d.rules.replace(/\n/g, '<br>')} />}
    {d.definition && <p class="ref-inline-rules">{d.definition}</p>}
    {d.see_also?.length > 0 && (
      <p class="ref-inline-seealso">
        See also:{' '}
        {d.see_also.map((s: string, i: number) => (
          <>{i > 0 && ', '}<a href={`#${s}`}>{s}</a></>
        ))}
      </p>
    )}
  </div>
)}

{d && effectiveVariant === 'stat' && (
  <div class="ref-stat">
    <table class="ref-stat-table">
      <tbody>
        <tr>
          <td class="sb-label">Stats</td>
          <td class="sb-data">
            <span class="sb-stat"><strong>HD</strong>{' '}{d.hd}{' '}({hp}{ap > 0 ? ` + ${ap} AP` : ''})</span>
            <span class="sb-stat"><strong>BR</strong>{' '}{br}</span>
            {d.size !== undefined && d.size !== null && d.size !== false && <span class="sb-stat"><strong>Size</strong>{' '}{d.size}'</span>}
            {weight && <span class="sb-stat"><strong>Weight</strong>{' '}{weight}</span>}
            {maxload && <span class="sb-stat"><strong>Max. Load</strong>{' '}{maxload}</span>}
            {speeds.length > 0 && speeds.map((s: { label: string; value: string }) => (
              <span class="sb-stat"><strong>{s.label}</strong>{' '}{s.value}</span>
            ))}
          </td>
        </tr>
        {d.group     && <tr><td class="sb-label">Group</td>     <td class="sb-data" set:html={mdToHtml(d.group)}></td></tr>}
        {(d.desc ?? d.summary) && <tr><td class="sb-label">Desc.</td>     <td class="sb-data" set:html={mdToHtml(d.desc ?? d.summary)}></td></tr>}
        {d.wants     && <tr><td class="sb-label">Wants</td>     <td class="sb-data" set:html={mdToHtml(d.wants)}></td></tr>}
        {d.intellect && <tr><td class="sb-label">Intellect</td> <td class="sb-data" set:html={mdToHtml(d.intellect)}></td></tr>}
        {d.morality  && <tr><td class="sb-label">Morality</td>  <td class="sb-data" set:html={mdToHtml(d.morality)}></td></tr>}
      </tbody>
    </table>

    {d.features?.length > 0 && (
      <div class="ref-stat-abilities">
        <ul class="ability-list">
          {d.features.map((a: { name: string; text: string }) => {
            const { intro, bullets } = renderFeatureText(a.text);
            return (
              <li>
              <strong>{a.name}</strong>: <span set:html={intro}></span>
              {bullets.length > 0 && (
              <ul class="ability-sub-list">
              {bullets.map((b: string) => <li set:html={b}></li>)}
              </ul>
              )}
              </li>
            );
          })}
        </ul>
      </div>
    )}

    {d.lore && (
      <div class="ref-stat-lore" set:html={renderLore(d.lore)} />
    )}

    {d.treasure && (
      <p class="ref-stat-treasure"><strong>Treasure</strong>: <span set:html={mdToHtml(d.treasure)}></span></p>
    )}

    {d.when_eaten && (
      <div class="ref-when-eaten">
        <div class="ref-when-eaten-head">When Eaten</div>
        {d.when_eaten.flavor && <p class="ref-when-eaten-flavor" set:html={mdToHtml(d.when_eaten.flavor)}></p>}
        {d.when_eaten.notes  && <p class="ref-when-eaten-notes" set:html={mdToHtml(d.when_eaten.notes)}></p>}
        {d.when_eaten.table && (
          <RollableTable
            die={d.when_eaten.table.die}
            entries={d.when_eaten.table.entries}
            label={d.when_eaten.table.label || 'Effects'}
          />
        )}
      </div>
    )}
  </div>
)}

<style>
  /* ── Missing reference ─────────────────────────────── */
  .ref-missing {
    color: var(--crimson-600);
    text-decoration: underline dotted;
    cursor: help;
  }
  .ref-missing::after { content: ' [?]'; font-size: 0.8em; opacity: 0.6; }

  /* ── Tooltip anchor ────────────────────────────────── */
  .ref-term {
    color: var(--link-col);
    text-decoration: underline dotted;
    position: relative;
    cursor: help;
  }
  .ref-term[data-tooltip]:not([data-tooltip=''])::after {
    content: attr(data-tooltip);
    position: absolute;
    bottom: calc(100% + 0.5em);
    left: 0;
    min-width: 14em;
    max-width: 22em;
    background: var(--nav-bg);
    color: var(--nav-text);
    padding: 0.55em 0.75em;
    border-radius: 0.25em;
    font-size: 0.82em;
    line-height: 1.5;
    z-index: 50;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s;
    border: 1px solid rgba(196,146,52,0.3);
    white-space: normal;
  }
  .ref-term[data-tooltip]:hover::after { opacity: 1; }

  /* ── Card ──────────────────────────────────────────── */
  .ref-card {
    display: block;
    padding: 0.85em 1em;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 0.25em;
    text-decoration: none;
    transition: border-color 0.15s;
  }
  .ref-card:hover { border-color: var(--gold-ui); text-decoration: none; }
  .ref-card-name {
    font-family: 'Literata Variable', serif;
    font-variant-caps: small-caps;
    font-weight: 700;
    color: var(--heading-col);
    display: block;
    margin-bottom: 0.25em;
  }
  .ref-card-summary {
    font-size: 0.85em;
    color: var(--text-soft);
    display: block;
    margin-bottom: 0.4em;
  }
  .ref-card-tags { display: flex; gap: 0.4em; flex-wrap: wrap; }
  .ref-tag {
    font-size: 0.68em;
    font-family: 'Literata Variable', serif;
    text-transform: capitalize; font-variant-caps: small-caps;
    font-weight: 700;
    padding: 0.15em 0.6em;
    background: var(--bg-elevated);
    color: var(--text-muted);
    border-radius: 0.2em;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    line-height: 1.2;
  }

  /* ── Inline block ──────────────────────────────────── */
  .ref-inline {
    background: var(--callout-ex-bg);
    border-left: 3px solid var(--callout-ex-bdr);
    padding: 0.85em 1.1em;
    margin: 1.2em 0;
    border-radius: 0 0.25em 0.25em 0;
  }
  .ref-inline-name {
    font-family: 'Literata Variable', serif;
    font-variant-caps: small-caps;
    font-weight: 700;
    font-size: 1.05em;
    color: var(--callout-ex-head);
    margin-bottom: 0.35em;
  }
  .ref-inline-summary { font-style: italic; color: var(--text-soft); margin-bottom: 0.4em; }
  .ref-inline-field   { font-size: 0.9em; color: var(--text-soft); margin-bottom: 0.2em; }
  .ref-inline-rules   { font-size: 0.9em; color: var(--text); margin-top: 0.5em; }
  .ref-inline-seealso { font-size: 0.8em; color: var(--text-muted); margin-top: 0.5em; }

  /* ── Stat block ────────────────────────────────────── */
  .ref-stat { margin: 1.5em 0; }
  .ref-stat-name {
    font-size: 2.2em;
    margin-bottom: 0.35em;
  }
  .ref-stat-tags {
    display: flex; gap: 0.4em; flex-wrap: wrap;
    margin: 0 0 0.65em;
    text-indent: 0;
  }
  .ref-stat-table {
    width: 100%; border-collapse: collapse;
    font-family: 'Literata Variable', serif; font-size: 0.9em;
  }
  .sb-label {
    font-variant-caps: small-caps; font-weight: 700; font-size: 1em;
    color: var(--text-soft); white-space: nowrap;
    padding: 0.4em 0.75em 0.4em 0;
    vertical-align: top; width: 6.5em; text-align: right;
  }
  .sb-data {
    border-left: 1px solid var(--table-rule);
    padding: 0.4em 0 0.4em 0.85em;
    color: var(--text); vertical-align: top;
  }
  .sb-stat {
    display: inline-block;
    margin-right: 0.65em;
    white-space: nowrap;
  }
  .ref-stat-abilities {
    margin-top: 0.85em; padding-top: 0.65em;
    border-top: 1px solid var(--border);
  }
  .ability-list { list-style: none; padding: 0; margin: 0; }
  .ability-list > li {
    font-family: 'Literata Variable', serif; font-size: 0.9em;
    line-height: 1.6;
  }
  .ability-sub-list {
    list-style: none;
    padding: 0;
    margin: 0.35em 0 0 1em;
  }
  .ability-sub-list > li {
  }
  .ref-stat-lore {
    margin-top: 1em; padding-top: 0.75em;
    border-top: 1px solid var(--border);
    font-size: 0.9em;
    color: var(--text);
  }
  .ref-stat-lore p { margin: 0.5em 0; }
  .ref-stat-treasure {
    font-family: 'Literata Variable', serif;
    font-size: 0.9em;
    color: var(--text);
    margin: 0.85em 0 0 0;
  }
  .ref-when-eaten {
    margin-top: 0.85em; padding: 0.7em 1em;
    background: var(--callout-rule-bg);
    border: 2px solid var(--callout-rule-bdr);
    border-radius: 0 0.25em 0.25em 0;
    font-family: 'Literata Variable', serif;
    font-size: 0.9em;
  }
  .ref-when-eaten-head {
    font-family: 'Literata Variable', serif;
    font-variant-caps: small-caps; font-weight: 700;
    font-size: 1.25em;
    letter-spacing: 0.04em;
    color: var(--callout-rule-head); margin-bottom: 0.35em;
  }
  .ref-when-eaten-flavor {
    font-style: italic; color: var(--flavor-col);
    margin: 0 0 0.3em;
  }
  .ref-when-eaten-notes { margin: 0; color: var(--text); }
</style>
