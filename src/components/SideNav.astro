---
import { nav } from '../config/nav';
import NavTree from './NavTree.astro';
import EmailReveal from './EmailReveal.astro';
import NavTreeNav from './NavTreeNav.astro';

const { currentPath = '', id } = Astro.props;
---

<nav class="side-nav" id={id} aria-label="Site navigation">
  <a href="/" class="nav-home-link" aria-label="Glass Empires SRD home">
    <img src="/logo/main.webp" alt="Glass Empires" class="nav-logo" />
    <span class="nav-wordmark-sub">System Reference Document</span>
  </a>

  <NavTreeNav {currentPath} />

  <div class="nav-scroll">
    <ul class="nav-list" id="nav-list">
      <NavTree items={nav} currentPath={currentPath} />
    </ul>
  </div>

  <button class="cyclopean-logo-btn" id="cyclopean-logo-btn" aria-label="About Cyclopean">
    <img src="/logo/cyclopean-logo-wordmark-white.svg" alt="Cyclopean" class="cyclopean-logo-img" />
  </button>
</nav>

<!-- Cyclopean Modal -->
<div class="modal-overlay" id="cyclopean-modal" aria-hidden="true" role="dialog" aria-modal="true" aria-label="About Cyclopean">
  <div class="modal-content modal-cyclopean">
    <button class="modal-close" id="cyclopean-modal-close" aria-label="Close">✕</button>
    <div class="modal-body">
      <img src="/logo/cyclopean-logo-wordmark-black.svg" alt="Cyclopean" class="cyclopean-modal-logo cyclopean-modal-logo-light" />
      <img src="/logo/cyclopean-logo-wordmark-white.svg" alt="Cyclopean" class="cyclopean-modal-logo cyclopean-modal-logo-dark" />
      <p class="cyclopean-provenance">Glass Empires is a game by <a href="https://sakiroku.com">Saki</a>, published by <strong>Cyclopean</strong>. I make a lot of weird stuff; you can check out the rest of it below.</p>
      <div class="cyclopean-links">
        <a href="https://glassempires.com" target="_blank" rel="noopener" class="cyclopean-link">
          <img src="/logo/main-wide.webp" alt="Glass Empires" class="cyclopean-link-logo cyclopean-link-logo-wide" />
          <span class="cyclopean-link-sub">Home</span>
        </a>
        <a href="https://dndungeon.com" target="_blank" rel="noopener" class="cyclopean-link">
          <img src="/logo/Logo-Icon-Name-Outline.svg" alt="DnDungeon" class="cyclopean-link-logo" />
          <span class="cyclopean-link-sub">Asian Fantasy Maps &amp; Assets</span>
        </a>
        <a href="https://sakiroku.com" target="_blank" rel="noopener" class="cyclopean-link">
          <img src="/logo/sakiroku-wordmark-thin-red.png" alt="Sakiroku" class="cyclopean-link-logo sakiroku-logo-light" />
          <img src="/logo/sakiroku-wordmark-thin-red-lighttext.png" alt="Sakiroku" class="cyclopean-link-logo sakiroku-logo-dark" />
          <span class="cyclopean-link-sub">RPG Blog</span>
        </a>
        <a href="https://www.drivethrurpg.com/en/publisher/24595/Cyclopean" target="_blank" rel="noopener" class="cyclopean-link">
          <img src="/logo/dtrpg.png" alt="DriveThruRPG" class="cyclopean-link-logo" />
          <span class="cyclopean-link-sub">Cyclopean's DTRPG Page</span>
        </a>
      </div>
      <p class="cyclopean-email">You can also email me at: <EmailReveal /></p>
    </div>
  </div>
</div>



<script>
  window.addEventListener("beforeunload", () => {
    const ns = document.querySelector(".nav-scroll");
    if (ns) sessionStorage.setItem("ge-nav-scroll", ns.scrollTop);
  });
</script>
<style>
  .side-nav {
    width: var(--nav-width);
    background: var(--nav-bg);
    color: var(--nav-text);
    height: 100dvh;
    position: sticky;
    top: 0;
    overflow: hidden;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    scrollbar-width: thin;
    scrollbar-color: rgba(196,146,52,0.2) transparent;
  }
  .nav-home-link {
    display: block;
    padding: 1.5em 1.25em 1.1em;
    border-bottom: 1px solid rgba(196,146,52,0.15);
    text-decoration: none;
    flex-shrink: 0;
  }
  .nav-scroll {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    padding-bottom: 0;
  }
  .nav-logo {
    display: block;
    width: 100%;
    height: auto;
    animation: logo-glow 4s ease-in-out infinite;
  }
  @keyframes logo-glow {
    0%, 100% { filter: drop-shadow(0 0 6px rgba(98,237,216,0.03)) drop-shadow(0 0 18px rgba(98,237,216,0.01)); }
    50%      { filter: drop-shadow(0 0 10px rgba(98,237,216,0.08)) drop-shadow(0 0 28px rgba(98,237,216,0.04)); }
  }
  .nav-wordmark-sub {
    display: block;
    font-family: 'Literata Variable', serif;
    font-variant-caps: small-caps;
    font-size: 0.7em;
    color: var(--nav-accent);
    letter-spacing: 0.15em;
    margin-top: 0.5em;
  }
  .nav-list {
    list-style: none;
    padding: 0 0 1em;
    flex: 1;
  }

  /* ── Cyclopean logo button ──────────────────────────── */
  .cyclopean-logo-btn {
    display: block;
    width: 100%;
    background: none;
    border: none;
    border-top: 1px solid rgba(196,146,52,0.15);
    padding: 0.75em 1.25em;
    cursor: pointer;
    color: var(--nav-accent);
    transition: background 0.15s, opacity 0.15s;
    flex-shrink: 0;
  }
  .cyclopean-logo-btn:hover {
    background: var(--nav-hover);
  }
  .cyclopean-logo-btn img {
    display: block;
    width: 100%;
    height: auto;
  }

  /* ── Cyclopean Modal ────────────────────────────────── */
  .modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 999;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,0,0,0.55);
    backdrop-filter: blur(4px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
  }
  .modal-overlay[aria-hidden="false"] {
    opacity: 1;
    pointer-events: auto;
  }
  .modal-content {
    position: relative;
    background: var(--bg-surface);
    border-top: 2px solid var(--border-strong);
    border-bottom: 2px solid var(--border-strong);
    border-left: none;
    border-right: none;
    border-radius: 1em;
    box-shadow: 0 8px 32px rgba(0,0,0,0.3);
    max-width: 90vw;
    padding: 2em 2em 1.5em;
  }
  .modal-close {
    position: absolute;
    top: 0.6em;
    right: 0.6em;
    background: none;
    border: none;
    font-size: 1.1em;
    cursor: pointer;
    color: var(--text-muted);
    width: 1.8em;
    height: 1.8em;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.2em;
    z-index: 1;
  }
  .modal-close:hover {
    color: var(--text);
    background: var(--nav-hover);
  }
  .modal-body {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1em;
  }
  .modal-cyclopean {
    max-width: 24em;
  }
  .cyclopean-modal-logo {
    display: block;
    width: 100%;
    max-width: 18em;
    height: auto;
  }
  .cyclopean-modal-logo-dark { display: none; }
  .cyclopean-modal-logo-light { display: block; }
  :global([data-theme="dark"]) .cyclopean-modal-logo-light { display: none; }
  :global([data-theme="dark"]) .cyclopean-modal-logo-dark { display: block; }
  .cyclopean-provenance {
    font-family: 'Literata Variable', serif;
    font-size: 0.85em;
    color: var(--text-soft);
    margin: 0;
    text-align: center;
    line-height: 1.6;
  }
  .cyclopean-links {
    display: flex;
    flex-direction: column;
    width: 100%;
    margin-top: 0.5em;
  }
  .cyclopean-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4em;
    padding: 0.75em 0.25em;
    text-decoration: none;
    color: var(--text);
    text-align: center;
    border-bottom: 1px solid var(--border);
  }
  .cyclopean-link:last-child {
    border-bottom: none;
  }
  .cyclopean-link:hover {
    text-decoration: none;
    opacity: 0.7;
  }
  .cyclopean-link-logo {
    display: block;
    height: 1.8em;
    width: auto;
  }
  .cyclopean-link-logo-wide {
    height: auto;
    width: 100%;
    max-width: 9em;
  }
  .sakiroku-logo-dark { display: none; }
  :global([data-theme="dark"]) .sakiroku-logo-light { display: none; }
  :global([data-theme="dark"]) .sakiroku-logo-dark { display: block; }
  .cyclopean-link-sub {
    font-size: 0.65em;
    font-variant-caps: small-caps;
    letter-spacing: 0.15em;
    color: var(--text-muted);
  }
  .cyclopean-email {
    font-size: 0.8em;
    color: var(--text-soft);
    margin: 0;
    text-align: center;
  }

  @media (max-width: 48em) {
    .side-nav {
      position: fixed;
      left: -100%;
      z-index: 200;
      transition: left 0.25s ease;
      width: min(var(--nav-width), 85vw);
    }
    .side-nav.is-open {
      left: 0;
    }
  }
</style>
