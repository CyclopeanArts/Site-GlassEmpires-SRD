---
import { getCollection, getEntry } from 'astro:content';
import BookLayout from '../../layouts/BookLayout.astro';

export async function getStaticPaths() {
  const tables = await getCollection('tables');
  return tables.map(t => ({ params: { slug: t.id } }));
}

const { slug } = Astro.params;
const entry = await getEntry('tables', slug!);
if (!entry) return Astro.redirect('/tables');

const d = entry.data;
---

<BookLayout title={d.name}>
  <h1>{d.name}</h1>
  {d.tags?.length > 0 && (
    <p class="tags">{d.tags.map((t: string) => <span class="tag">{t}</span>)}</p>
  )}

  <table class="ge-table">
    <thead>
      <tr>
        <th class="center">{d.die}</th>
        <th>Result</th>
      </tr>
    </thead>
    <tbody>
      {d.entries.map((e: { roll: string; result: string }) => (
        <tr>
          <td class="center">{e.roll}</td>
          <td>{e.result}</td>
        </tr>
      ))}
    </tbody>
  </table>
</BookLayout>

<style>
  .tags { display: flex; gap: 0.4em; flex-wrap: wrap; margin: 0.5em 0 1.5em; }
  .tag { font-size: 0.75em; padding: 0.2em 0.55em; background: var(--surface-2); border-radius: 3px; color: var(--text-muted); font-variant-caps: small-caps; }
  .ge-table { width: 100%; border-collapse: collapse; font-size: 0.9em; margin-top: 1em; }
  .ge-table thead tr { border-bottom: 1px solid var(--table-rule); }
  .ge-table th { font-variant-caps: small-caps; font-weight: 700; padding: 0.45em 0.75em; color: var(--text-soft); text-align: left; }
  .ge-table td { padding: 0.45em 0.75em; vertical-align: top; }
  .ge-table tr:nth-child(even) { background: var(--surface-2); }
  .center { text-align: center; }
</style>
