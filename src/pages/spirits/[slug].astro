---
import { getCollection, getEntry } from "astro:content";
import { getSlugMap } from "../../config/slug-resolver.js";
import BookLayout from "../../layouts/BookLayout.astro";
import Ref from "../../components/Ref.astro";
import { renderFullMarkdown } from "../../utils/markdown.js";

export async function getStaticPaths() {
  const spirits = await getCollection("spirits");
  return spirits.map(s => ({ params: { slug: s.id } }));
}

const { slug } = Astro.params;
const entry = await getEntry("spirits", slug);
if (!entry) return Astro.redirect("/spirits");

const d = entry.data;
const _slugMap = getSlugMap();

function formatSave() {
  if (!d.save) return "";
  if (typeof d.save === "string") return d.save;
  return d.save.type || "";
}
---

<BookLayout title={d.name}>
  <div class="spirit-body">
    {d.duration && <p class="spirit-field"><strong>Duration:</strong> {d.duration}</p>}
    {d.cost && <p class="spirit-field"><strong>Cost:</strong> {d.cost}</p>}
    {d.trigger && <p class="spirit-field"><strong>Trigger:</strong> {d.trigger}</p>}
    {formatSave() && <p class="spirit-field"><strong>Save:</strong> {formatSave()}</p>}
    {d.rules && <div class="spirit-rules" set:html={renderFullMarkdown(d.rules, _slugMap)} />}
  </div>

  {d.see_also?.length > 0 && (
    <section class="see-also">
      <h3>See Also</h3>
      <div class="see-also-grid">
        {d.see_also.map((s) => <Ref slug={s} />)}
      </div>
    </section>
  )}
</BookLayout>

<style>
  .spirit-body { font-size: 1em; line-height: 1.65; }
  .spirit-field { font-size: 0.92em; color: var(--text-soft); margin: 0.15em 0; line-height: 1.5; }
  .spirit-field strong { color: var(--text); font-weight: 600; margin-right: 0.25em; }
  .spirit-rules { font-size: 1em; color: var(--text); margin-top: 0.6em; line-height: 1.65; }
  .spirit-rules p { margin: 0.5em 0; }
  .spirit-rules ul, .spirit-rules ol { margin: 0.4em 0; padding-left: 1.4em; }
  .spirit-rules li { margin: 0.15em 0; }
  .see-also { margin-top: 2.5em; }
  .see-also-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(14em, 1fr)); gap: 0.65em; margin-top: 0.75em; }
</style>