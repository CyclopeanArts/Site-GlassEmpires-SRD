---
import { getCollection, getEntry } from 'astro:content';
import BookLayout from '../../layouts/BookLayout.astro';
import Callout from '../../components/Callout.astro';
import Ref from '../../components/Ref.astro';
import RollableTable from '../../components/RollableTable.astro';

export async function getStaticPaths() {
  const allEntries = await getCollection('bestiary');
  const slugToId: Record<string, string> = {};
  for (const e of allEntries) {
    const flat = e.id.split('/').pop()!.replace(/\.(yaml|mdx)$/, '');
    slugToId[flat] = e.id;
  }
  return Object.keys(slugToId).map(slug => ({ params: { slug } }));
}

const allEntries = await getCollection('bestiary');
const slugToId: Record<string, string> = {};
for (const e of allEntries) {
  const flat = e.id.split('/').pop()!.replace(/\.(yaml|mdx)$/, '');
  slugToId[flat] = e.id;
}

const { slug } = Astro.params;
const fullId = slugToId[slug!];
const entry = fullId ? await getEntry('bestiary', fullId) : null;
if (!entry) return Astro.redirect('/bestiary');
const d = entry.data;

function renderBestiaryBody(text: string): string {
  const blocks = text.split(/\n\n+/);
  const parts: string[] = [];
  for (const block of blocks) {
    const lines = block.split('\n');
    const hasBullets = lines.some(l => l.trimStart().startsWith('- '));
    if (hasBullets) {
      const items = lines
        .filter(l => l.trimStart().startsWith('- '))
        .map(l => `<li>${l.trimStart().slice(2).trim().replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>').replace(/\*(.+?)\*/g, '<em>$1</em>')}</li>`);
      parts.push(`<ul>${items.join('\n')}</ul>`);
    } else {
      parts.push(`<p>${block.replace(/\n/g, '<br>').replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>').replace(/\*(.+?)\*/g, '<em>$1</em>')}</p>`);
    }
  }
  return parts.join('\n');
}

const all = allEntries
  .map(e => ({
    slug: e.id.split('/').pop()!.replace(/\.(yaml|mdx)$/, ''),
    name: e.data.name
  }))
  .sort((a, b) => a.name.localeCompare(b.name));
const idx = all.findIndex(e => e.slug === slug);
const prev = idx > 0 ? all[idx - 1] : null;
const next = idx < all.length - 1 ? all[idx + 1] : null;
---

<BookLayout title={d.name} tags={d.tags}>
  <Ref collection="bestiary" slug={fullId!} variant="stat" />

  {d.gm_note && (
    <Callout type="gm" heading={d.gm_note.heading}>
      <div class="callout-body-content" set:html={renderBestiaryBody(d.gm_note.body)} />
    </Callout>
  )}

  {d.tables?.length > 0 && d.tables.map((t: any) => (
    <RollableTable label={t.label} die={t.die} entries={t.entries} />
  ))}

  <nav class="bestiary-nav" aria-label="Bestiary navigation">
    {prev
      ? <a href={`/bestiary/${prev.slug}`} class="bn-prev">← {prev.name}</a>
      : <span />
    }
    <a href="/bestiary" class="bn-index">Index</a>
    {next
      ? <a href={`/bestiary/${next.slug}`} class="bn-next">{next.name} →</a>
      : <span />
    }
  </nav>
</BookLayout>

<style>
  .bestiary-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 3em;
    padding-top: 1em;
    border-top: 1px solid var(--border);
  }
  .bestiary-nav a {
    font-family: 'Literata Variable', serif;
    font-variant-caps: small-caps;
    font-weight: 700;
    font-size: 0.85em;
    color: var(--link-col);
    text-decoration: none;
    transition: color 0.15s;
  }
  .bestiary-nav a:hover { color: var(--accent); text-decoration: none; }
  .bn-prev { text-align: left; }
  .bn-next { text-align: right; }
  .bn-index {
    font-size: 0.75em;
    color: var(--text-muted) !important;
  }
  .bn-index:hover { color: var(--text) !important; }
</style>
