---
import { getCollection } from 'astro:content';
import BookLayout from '../../layouts/BookLayout.astro';

const all = await getCollection('bestiary');

const tagMap = new Map<string, typeof all>();
for (const entry of all) {
  for (const tag of entry.data.tags ?? []) {
    if (!tagMap.has(tag)) tagMap.set(tag, []);
    tagMap.get(tag)!.push(entry);
  }
}
const tags = [...tagMap.entries()].sort((a, b) => a[0].localeCompare(b[0]));
---

<BookLayout title="Bestiary — All Tags">
  <h1>Bestiary Tags</h1>
  <hr class="rule-divider" />

  {tags.length === 0 ? (
    <p class="empty-note">No tags yet.</p>
  ) : tags.map(([tag, entries]) => (
    <section class="tag-section">
      <h2 class="tag-heading">{tag}</h2>
      <ul class="creature-list">
        {entries.sort((a, b) => a.data.name.localeCompare(b.data.name)).map(e => (
          <li><a href={`/bestiary/${e.id}`}>{e.data.name}</a></li>
        ))}
      </ul>
    </section>
  ))}
</BookLayout>

<style>
  .tag-section { margin-top: 1.75em; }
  .tag-heading {
    font-variant-caps: small-caps; font-size: 1em;
    color: var(--text-muted); letter-spacing: 0.08em;
    border-bottom: 1px solid var(--border-subtle);
    padding-bottom: 0.25em; margin-bottom: 0.5em;
  }
  .creature-list { list-style: none; padding: 0; columns: 2; gap: 1em; }
  .creature-list li { padding: 0.15em 0; }
  .creature-list a { color: var(--link); }
  .empty-note { color: var(--text-muted); font-style: italic; }

  @media (max-width: 32em) {
    .creature-list { columns: 1; }
  }
</style>
