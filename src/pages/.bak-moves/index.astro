---
import { getCollection } from 'astro:content';
import BookLayout from '../../layouts/BookLayout.astro';
import Ref from '../../components/Ref.astro';

const moves = (await getCollection('moves'))
  .sort((a, b) => a.data.name.localeCompare(b.data.name));
---

<BookLayout title="Moves">
  <p class="section-intro">
    Moves are discrete actions a character can take during play.
    Each move has a specific trigger, cost, and effect.
  </p>

  <div class="index-grid">
    {moves.map(m => (
      <Ref collection="moves" slug={m.id} variant="card" />
    ))}
    {moves.length === 0 && (
      <p class="empty-note">No moves written yet.</p>
    )}
  </div>
</BookLayout>

<style>
  .section-intro { font-style: italic; color: var(--text-muted); margin-bottom: 2em; max-width: 36em; }
  .index-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(16em, 1fr));
    gap: 0.75em;
  }
  .empty-note { color: var(--text-muted); font-style: italic; }
</style>
