---
import { getCollection } from 'astro:content';
import BookLayout from '../../layouts/BookLayout.astro';
import Ref from '../../components/Ref.astro';

const actions = (await getCollection('actions'))
  .sort((a, b) => a.data.name.localeCompare(b.data.name));
---

<BookLayout title="Actions Index">
  <p class="section-intro">
    Actions are discrete things a character or Faction can do during play.
    Each action has a specific trigger, duration, and possibly a Save.
  </p>

  <div class="index-grid">
    {actions.map(a => (
      <Ref collection="actions" slug={a.id} variant="card" />
    ))}
    {actions.length === 0 && (
      <p class="empty-note">No actions written yet.</p>
    )}
  </div>
</BookLayout>

<style>
  .section-intro { font-style: italic; color: var(--text-muted); margin-bottom: 2em; max-width: 36em; }
  .index-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(16em, 1fr));
    gap: 0.75em;
  }
  .empty-note { color: var(--text-muted); font-style: italic; }
</style>
