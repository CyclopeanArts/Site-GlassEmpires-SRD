---
import { getCollection } from 'astro:content';
import BookLayout from '../../layouts/BookLayout.astro';

const terms = (await getCollection('glossary'))
  .sort((a, b) => a.data.name.localeCompare(b.data.name));
---

<BookLayout title="Glossary">
  <h1>Glossary</h1>
  <hr class="rule-divider" />

  {terms.length === 0 ? (
    <p class="empty-note">No glossary terms written yet.</p>
  ) : (
    <dl class="glossary-list">
      {terms.map(t => (
        <div class="glossary-entry">
          <dt><a href={`/glossary/${t.id}`}>{t.data.name}</a></dt>
          {t.data.summary && <dd class="summary">{t.data.summary}</dd>}
          {(t.data as any).definition && <dd class="definition">{(t.data as any).definition}</dd>}
        </div>
      ))}
    </dl>
  )}
</BookLayout>

<style>
  .glossary-list { margin: 0; padding: 0; }
  .glossary-entry {
    padding: 0.75em 0;
    border-bottom: 1px solid var(--border-subtle);
  }
  dt { font-weight: 700; font-size: 1.05em; }
  dt a { color: var(--link); text-decoration: none; }
  dt a:hover { text-decoration: underline; }
  .summary { color: var(--text-muted); font-style: italic; margin: 0.1em 0 0 1em; }
  .definition { margin: 0.25em 0 0 1em; }
  .empty-note { color: var(--text-muted); font-style: italic; }
</style>
